<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Badminton Stats - Test joueurs</title>
</head>
<body>
  <h1>Liste des joueurs</h1>
  <div id="playersList">Chargement...</div>

  <script>
    const API_URL = 'https://script.google.com/macros/s/AKfycbzZQbFDtzig2SpsAD8cwf6n6EAePKEGaaOr224epaU/dev';

    async function loadPlayers() {
      const container = document.getElementById('playersList');

      try {
        const response = await fetch(`${API_URL}?action=getPlayers`);
        const result = await response.json();

        if (!result.ok) {
          container.textContent = 'Erreur API : ' + result.error;
          return;
        }

        container.innerHTML = result.data.map(player => `
          <div style="margin-bottom:8px;">
            <strong>${player.player_id}</strong> — ${player.nom}
          </div>
        `).join('');
      } catch (error) {
        container.textContent = 'Erreur fetch : ' + error;
      }
    }

    loadPlayers();
  </script>
</body>
</html>
